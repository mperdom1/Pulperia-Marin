<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5">

    <ImageView
        android:id="@+id/ivMainLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_basket"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pulpería Marín"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        app:layout_constraintTop_toBottomOf="@id/ivMainLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de Gestión de Inventario"
        android:textSize="14sp"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProducts"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="Inventario de Productos"
        app:icon="@android:drawable/ic_menu_agenda"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#333333"
        app:iconTint="#2E7D32"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"
        style="@style/Widget.Material3.Button.ElevatedButton"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMovements"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="Entradas y Salidas"
        app:icon="@android:drawable/ic_menu_sort_alphabetically"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#333333"
        app:iconTint="#2E7D32"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnProducts"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        style="@style/Widget.Material3.Button.ElevatedButton"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSummary"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="Resumen Financiero"
        app:icon="@android:drawable/ic_menu_report_image"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#333333"
        app:iconTint="#2E7D32"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnMovements"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        style="@style/Widget.Material3.Button.ElevatedButton"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0 - Pulpería Marín"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>